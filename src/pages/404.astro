---
import BaseLayout from '../layouts/BaseLayout.astro';
import Starfield from '../components/Starfield.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page introuvable — Morgane"
  description="Cette page n'existe pas. Retourne à l'accueil pour télécharger Morgane."
  path="/404"
  noindex
>
  <div class="page">
    <Starfield />

    <Nav />

    <main>
      <section>
        <p class="code mono">404</p>
        <h1 class="serif">Cette histoire <span class="accent">n'existe pas.</span></h1>
        <p class="sub">La page que tu cherches a été déplacée, ou n'a jamais été écrite.</p>
        <a class="btn" href="/">Retour à l'accueil</a>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page {
    position: relative;
    overflow-x: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: radial-gradient(
      140% 100% at 50% -10%,
      oklch(0.28 0.09 295) 0%,
      oklch(0.17 0.06 285) 42%,
      oklch(0.11 0.04 280) 100%
    );
  }

  main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  section {
    position: relative;
    z-index: 1;
    padding: 80px 32px;
    text-align: center;
  }

  .code {
    margin: 0 0 18px;
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--amber);
  }

  h1 {
    font-size: clamp(38px, 6vw, 64px);
    line-height: 1.05;
    margin: 0 0 18px;
  }

  .sub {
    font-size: 17px;
    color: var(--text-3);
    margin: 0 0 32px;
  }

  .btn {
    display: inline-flex;
    padding: 14px 26px;
    border-radius: 999px;
    background: var(--amber);
    color: oklch(0.15 0.04 285);
    font-size: 15px;
    font-weight: 600;
  }

  .btn:hover {
    background: var(--amber-hi);
    color: oklch(0.15 0.04 285);
  }
</style>
