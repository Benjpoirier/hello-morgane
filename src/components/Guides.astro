---
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);
---

<section id="guides">
  <header class="head">
    <p class="eyebrow">guides</p>
    <h2 class="serif">Comprendre la Merlin, <span class="accent">avant de t'y attaquer</span></h2>
  </header>

  <ul class="grid">
    {
      guides.map((guide) => (
        <li>
          <a class="card" href={`/${guide.id}/`}>
            <h3>{guide.data.heading}</h3>
            <p>{guide.data.description}</p>
            <span class="more">Lire le guide →</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  section {
    position: relative;
    z-index: 1;
    max-width: var(--shell);
    margin: 0 auto;
    padding: 90px 32px 40px;
  }

  .head {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto 56px;
  }

  h2 {
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.06;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 26px;
    border: 1px solid var(--hairline);
    border-radius: 18px;
    background: var(--panel);
    backdrop-filter: blur(6px);
    color: inherit;
    transition:
      border-color 0.25s,
      transform 0.2s;
  }

  .card:hover {
    border-color: oklch(0.84 0.12 80 / 0.45);
    transform: translateY(-3px);
    color: inherit;
  }

  h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 10px;
    color: #fff;
    letter-spacing: -0.01em;
  }

  p {
    flex: 1;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--text-3);
    margin: 0 0 16px;
  }

  .more {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--amber);
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    section {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
