---
import Icon from '../Icon.astro';
import { categories, changeset, host } from '../../data/app';

const groups = [
  { key: 'add', label: 'À ajouter', items: changeset.add, tone: 'ok' },
  { key: 'edit', label: 'Modifier', items: changeset.edit, tone: 'warn' },
  { key: 'remove', label: 'Supprimer', items: changeset.remove, tone: 'bad' },
] as const;
---

<div class="panes">
  <div class="side">
    <div class="tools">
      <span class="tbtn">
        <Icon name="refresh" size={14} />
        Actualiser
      </span>
      <span class="tbtn">
        <Icon name="folder-plus" size={14} />
        Catégorie
      </span>
    </div>

    <p class="pending">
      <Icon name="inbox" size={16} />
      <span class="p-label">À synchroniser</span>
      <span class="p-count mono" data-sel-count>3</span>
    </p>

    <span class="sep"></span>

    {
      categories.map((c) => (
        <p class="cat">
          <span class:list={['c-icon', { star: c.star }]}>
            <Icon name={c.star ? 'star' : 'folder'} size={15} />
          </span>
          <span class="c-label">{c.title}</span>
          <span class="c-count mono">{c.count}</span>
        </p>
      ))
    }

    <p class="tools-label">Outils</p>
    <p class="cat">
      <span class="c-icon"><Icon name="search" size={15} /></span>
      <span class="c-label">Fichiers retrouvés</span>
    </p>
    <p class="cat">
      <span class="c-icon"><Icon name="stethoscope" size={15} /></span>
      <span class="c-label">Vérifier l'intégrité</span>
    </p>
  </div>

  <div class="main-pane">
    <div class="strip">
      <span class="strip-a"><span data-sel-count>3</span> épisode(s) sélectionné(s)</span>
      <span class="strip-b">
        <Icon name="speaker" size={14} />
        <span class="mono">{host}</span>
      </span>
    </div>

    <div class="changeset">
      {
        groups.map((g) => (
          <div class="group">
            <p class:list={['g-head', g.tone]}>
              <span class="bar" />
              {g.label}
              <span class="g-count mono">{g.items.length}</span>
            </p>
            <ul class:list={['g-list', g.tone]}>
              {g.items.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="foot">
      <span class="foot-txt">3 groupe(s) · 1 suppression(s) · 1 édition(s)</span>
      <button class="go" type="button" data-sync>Synchroniser</button>
    </div>
  </div>
</div>

<style>
  .panes {
    flex: 1;
    min-height: 0;
    display: flex;
  }

  .side {
    width: 288px;
    flex-shrink: 0;
    border-right: 1px solid var(--a-border);
    padding: 10px 8px;
    overflow-y: auto;
  }

  .tools {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
  }

  .tbtn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 7px;
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 8px;
    font-size: 12px;
    color: oklch(0.93 0.02 300 / 0.85);
  }

  .pending {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 0;
    padding: 9px 10px;
    border-radius: 8px;
    background: oklch(0.74 0.18 315 / 0.12);
    color: var(--a-primary);
    font-size: 13px;
    font-weight: 600;
  }

  .p-label {
    flex: 1;
  }

  .p-count {
    font-size: 12px;
    font-variant-numeric: tabular-nums;
  }

  .sep {
    display: block;
    height: 1px;
    background: var(--a-border);
    margin: 8px 4px;
  }

  .cat {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 0;
    padding: 7px 10px;
    border-radius: 8px;
    font-size: 13px;
    color: oklch(0.93 0.02 300 / 0.85);
  }

  .c-icon {
    display: flex;
    color: var(--a-muted);
  }

  .c-icon.star {
    color: var(--a-brand);
  }

  .c-label {
    flex: 1;
  }

  .c-count {
    font-size: 12px;
    color: var(--a-muted);
    font-variant-numeric: tabular-nums;
  }

  .tools-label {
    margin: 14px 0 4px;
    padding: 0 10px;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--a-muted);
  }

  .main-pane {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    border-bottom: 1px solid var(--a-border);
  }

  .strip-a {
    font-size: 13px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .strip-b {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11.5px;
    color: var(--a-muted);
  }

  .changeset {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 14px 18px;
  }

  .group + .group {
    margin-top: 16px;
  }

  .g-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bar {
    width: 4px;
    height: 16px;
    border-radius: 999px;
    background: currentColor;
  }

  .g-count {
    font-size: 10.5px;
    padding: 1px 6px;
    border-radius: 999px;
    background: color-mix(in oklch, currentColor 15%, transparent);
    font-variant-numeric: tabular-nums;
  }

  .g-head.ok {
    color: var(--a-success);
  }
  .g-head.warn {
    color: var(--a-brand);
  }
  .g-head.bad {
    color: var(--a-destructive);
  }

  .g-list {
    list-style: none;
    margin: 0;
    padding: 0 0 0 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-left: 2px solid;
    font-size: 12.5px;
    color: oklch(0.93 0.02 300 / 0.9);
  }

  .g-list.ok {
    border-color: oklch(0.72 0.19 149 / 0.35);
  }
  .g-list.warn {
    border-color: oklch(0.84 0.12 80 / 0.35);
  }
  .g-list.bad {
    border-color: oklch(0.62 0.22 25 / 0.35);
  }

  .g-list li {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 11px 16px;
    border-top: 1px solid var(--a-border);
  }

  .foot-txt {
    font-size: 12.5px;
    color: var(--a-muted);
    font-variant-numeric: tabular-nums;
  }

  .go {
    padding: 9px 20px;
    border: none;
    border-radius: 9px;
    background: var(--a-primary);
    color: oklch(0.16 0.04 288);
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
  }

  .go:hover {
    filter: brightness(1.08);
  }
</style>
