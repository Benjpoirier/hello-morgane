---
import Icon from '../Icon.astro';
import { feeds, episodes } from '../../data/app';
---

<div class="panes">
  <div class="feeds">
    <div class="toolbar">
      <span class="search">
        <Icon name="search" size={14} />
        Rechercher…
      </span>
      <span class="add">
        <Icon name="plus" size={16} />
      </span>
    </div>

    <ul class="feed-list">
      {
        feeds.map((f) => (
          <li class:list={['feed', { active: f.active }]}>
            <span class="thumb t36" />
            <span class="feed-title">{f.title}</span>
            {f.fresh && <span class="fresh">{f.fresh}</span>}
            {
              f.active ? (
                <span class="feed-badge sel mono">
                  <span data-sel-count>3</span> sél.
                </span>
              ) : (
                <span class="feed-badge mono">{f.total} ép.</span>
              )
            }
          </li>
        ))
      }
    </ul>
  </div>

  <div class="detail">
    <header class="detail-head">
      <span class="thumb t48" />
      <span class="head-text">
        <span class="head-title">Les Odyssées</span>
        <span class="head-sub">
          <span class="box" />
          Afficher seulement les sélectionnés
        </span>
      </span>
      <span class="seen">
        <Icon name="check" size={14} />
        Marquer vus (3)
      </span>
    </header>

    <ul class="eps">
      {
        episodes.map((e) => (
          <li class:list={['ep', { current: e.playing }]}>
            <label class="pick">
              <input type="checkbox" checked={e.on} data-ep />
              <span class="box">
                <Icon name="check" size={11} stroke={3.5} />
              </span>
            </label>

            <span class="thumb t28" />

            <span class:list={['play', { current: e.playing }]}>
              {
                e.playing ? (
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <rect x="6" y="5" width="4" height="14" rx="1" />
                    <rect x="14" y="5" width="4" height="14" rx="1" />
                  </svg>
                ) : (
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                )
              }
            </span>

            <span class="ep-text">
              <span class="ep-line">
                <span class="ep-title">{e.title}</span>
                {e.fresh && <span class="new">New</span>}
                {e.bytes && (
                  <span class="bytes mono" title="L'enceinte tronque les titres au-delà de 66 octets">
                    66+
                  </span>
                )}
              </span>
              <span class="ep-date mono">{e.date}</span>
            </span>

            <span class="ep-n mono">#{e.n}</span>
            <span class="ep-img"><Icon name="image" size={14} /></span>
            <span class="ep-state">{e.synced && <Icon name="check" size={15} />}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  .panes {
    flex: 1;
    min-height: 0;
    display: flex;
  }

  .feeds {
    width: 288px;
    flex-shrink: 0;
    border-right: 1px solid var(--a-border);
    display: flex;
    flex-direction: column;
  }

  .toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 12px 8px;
  }

  .search {
    flex: 1;
    height: 36px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 10px;
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 8px;
    color: var(--a-muted);
    font-size: 13px;
  }

  .add {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 8px;
    color: oklch(0.93 0.02 300 / 0.75);
  }

  .feed-list {
    flex: 1;
    list-style: none;
    margin: 0;
    padding: 2px 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .feed {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    border-radius: 8px;
  }

  .feed.active {
    background: oklch(0.74 0.18 315 / 0.12);
  }

  .feed-title {
    flex: 1;
    min-width: 0;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fresh {
    font-size: 10px;
    font-weight: 600;
    color: #fff;
    background: var(--a-success);
    border-radius: 999px;
    padding: 1px 6px;
    font-variant-numeric: tabular-nums;
  }

  .feed-badge {
    font-size: 11px;
    color: var(--a-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .feed-badge.sel {
    color: var(--a-primary);
  }

  .detail {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .detail-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--a-border);
  }

  .head-text {
    flex: 1;
    min-width: 0;
  }

  .head-title {
    display: block;
    font-size: 18px;
    font-weight: 600;
  }

  .head-sub {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-top: 4px;
    font-size: 13px;
    color: var(--a-muted);
  }

  .seen {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 8px;
    font-size: 12px;
    color: oklch(0.93 0.02 300 / 0.85);
    white-space: nowrap;
  }

  .eps {
    flex: 1;
    list-style: none;
    margin: 0;
    padding: 8px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow-y: auto;
  }

  .ep {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 5px 8px;
    border-radius: 8px;
  }

  .ep.current {
    background: oklch(1 0 0 / 0.04);
  }

  .pick {
    display: flex;
    cursor: pointer;
  }

  .pick input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .box {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid oklch(1 0 0 / 0.3);
    border-radius: 4px;
    color: transparent;
  }

  .pick input:checked + .box {
    background: var(--a-primary);
    border-color: var(--a-primary);
    color: oklch(0.16 0.04 288);
  }

  .pick input:focus-visible + .box {
    outline: 2px solid var(--a-primary);
    outline-offset: 2px;
  }

  .play {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 50%;
    color: var(--a-muted);
  }

  .play.current {
    border-color: var(--a-primary);
    color: var(--a-primary);
  }

  .ep-text {
    flex: 1;
    min-width: 0;
  }

  .ep-line {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }

  .ep-title {
    min-width: 0;
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .new {
    flex-shrink: 0;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--a-success);
    background: oklch(0.72 0.19 149 / 0.15);
    border-radius: 4px;
    padding: 1px 4px;
  }

  .bytes {
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 600;
    color: var(--a-brand);
    background: oklch(0.84 0.12 80 / 0.2);
    border-radius: 4px;
    padding: 1px 4px;
  }

  .ep-date {
    display: block;
    font-size: 11px;
    color: var(--a-muted);
    font-variant-numeric: tabular-nums;
  }

  .ep-n,
  .ep-img,
  .ep-state {
    flex-shrink: 0;
    font-size: 11px;
    color: var(--a-muted);
    font-variant-numeric: tabular-nums;
  }

  .ep-state {
    width: 15px;
    color: var(--a-success);
  }
</style>
