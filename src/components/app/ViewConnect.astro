---
import Logo from '../Logo.astro';
import Icon from '../Icon.astro';
import { host } from '../../data/app';

const [ip, port] = host.split(':');
---

<div class="connect">
  <div class="orb">
    <span class="ring"></span>
    <span class="ring"></span>
    <span class="ring"></span>
    <span class="core"></span>
    <Logo size={44} class="mark" />
    <span class="moonlet"></span>
  </div>

  <p class="state serif">Enceinte connectée</p>
  <p class="host mono">{host} · ping 12 ms</p>

  <div class="fields">
    <label class="field">
      <span class="lbl">Hôte</span>
      <span class="input mono">{ip}</span>
    </label>
    <label class="field">
      <span class="lbl">Port</span>
      <span class="input mono">{port}</span>
    </label>
  </div>

  <div class="devices">
    <p class="dev-label">Mes Merlin</p>
    <p class="dev">
      <Icon name="speaker" size={16} />
      <span class="dev-name">Merlin de Jeanne</span>
      <span class="dev-on">connectée</span>
    </p>
    <p class="dev">
      <Icon name="speaker" size={16} />
      <span class="dev-name">Merlin d'Arthur</span>
    </p>
  </div>
</div>

<style>
  .connect {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
  }

  .orb {
    position: relative;
    width: 150px;
    height: 150px;
    margin-bottom: 22px;
    animation: n-float 7s ease-in-out infinite;
  }

  .ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid oklch(0.7 0.16 305 / 0.5);
    animation: n-ring 4s ease-out infinite;
  }

  .ring:nth-of-type(2) {
    animation-delay: 1.3s;
  }

  .ring:nth-of-type(3) {
    animation-delay: 2.6s;
  }

  .core {
    position: absolute;
    inset: 26px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 30%,
      oklch(0.82 0.13 320),
      oklch(0.58 0.22 300) 55%,
      oklch(0.4 0.2 295)
    );
    box-shadow: 0 0 50px oklch(0.6 0.22 305 / 0.6);
  }

  .orb :global(.mark) {
    position: absolute;
    top: 53px;
    left: 53px;
    color: oklch(0.98 0.02 90);
  }

  .moonlet {
    position: absolute;
    top: 6px;
    right: 22px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: oklch(0.92 0.09 85);
    box-shadow: 0 0 16px oklch(0.9 0.12 85);
  }

  .state {
    margin: 0;
    font-size: 26px;
    color: var(--a-fg);
  }

  .host {
    margin: 6px 0 0;
    font-size: 12px;
    color: var(--a-muted);
    font-variant-numeric: tabular-nums;
  }

  .fields {
    display: flex;
    gap: 12px;
    margin-top: 22px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: left;
  }

  .lbl {
    font-size: 11px;
    color: var(--a-muted);
  }

  .input {
    display: flex;
    align-items: center;
    height: 34px;
    padding: 0 12px;
    border: 1px solid oklch(1 0 0 / 0.12);
    border-radius: 8px;
    font-size: 12.5px;
    color: var(--a-fg);
  }

  .devices {
    width: 260px;
    margin-top: 26px;
    text-align: left;
  }

  .dev-label {
    margin: 0 0 8px;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--a-muted);
  }

  .dev {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 0 0 4px;
    padding: 8px 10px;
    border-radius: 8px;
    background: oklch(1 0 0 / 0.04);
    color: var(--a-muted);
  }

  .dev-name {
    flex: 1;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--a-fg);
  }

  .dev-on {
    font-size: 11px;
    color: var(--a-success);
  }
</style>
