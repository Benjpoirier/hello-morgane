---
import Icon from './Icon.astro';
import GithubIcon from './GithubIcon.astro';
import Logo from './Logo.astro';
import AppWindow from './AppWindow.astro';
import { links } from '../data/site';
---

<section id="top" class="hero">
  <p class="badge mono">
    <span class="dot" aria-hidden="true"></span>
    libre · open source · bêta
  </p>

  <div class="orb" aria-hidden="true">
    <span class="ring"></span>
    <span class="ring"></span>
    <span class="ring"></span>
    <span class="core"></span>
    <Logo size={42} class="orb-mark" />
    <span class="moonlet"></span>
  </div>

  <h1 class="serif">
    Toutes les histoires du monde,<br />
    <span class="accent">racontées par ta Merlin.</span>
  </h1>

  <p class="lede">
    <strong>Morgane</strong> est une application de bureau qui transfère n'importe quel podcast RSS
    vers l'enceinte pour enfants Merlin, en Wi-Fi direct. Tu t'abonnes, tu choisis les épisodes,
    Morgane les convertit et les synchronise sur la boîte. Aucun compte, aucun cloud.
  </p>

  <div class="cta-row">
    <a class="btn btn-primary" href="#get">
      <Icon name="download" size={18} stroke={2.2} />
      Télécharger Morgane
    </a>
    <a class="btn btn-ghost" href={links.github} rel="noopener">
      <GithubIcon size={18} />
      GitHub
    </a>
    <a class="btn btn-ghost" href={links.donate} rel="noopener">
      <Icon name="heart" size={18} />
      Soutenir
    </a>
  </div>

  <div class="window-wrap">
    <div class="window-glow" aria-hidden="true"></div>
    <AppWindow />
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    margin: 0 auto;
    padding: 44px 32px 40px;
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin: 0 0 28px;
    padding: 6px 15px;
    font-size: 12px;
    color: oklch(0.8 0.08 80);
    border: 1px solid oklch(0.84 0.12 80 / 0.35);
    border-radius: 999px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber-glow);
    box-shadow: 0 0 10px var(--amber-glow);
  }

  .orb {
    position: relative;
    width: 172px;
    height: 172px;
    margin: 0 auto 34px;
    animation: n-float 7s ease-in-out infinite;
  }

  .ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid oklch(0.7 0.16 305 / 0.5);
    animation: n-ring 4s ease-out infinite;
  }

  .ring:nth-of-type(2) {
    animation-delay: 1.3s;
  }

  .ring:nth-of-type(3) {
    animation-delay: 2.6s;
  }

  .core {
    position: absolute;
    inset: 28px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 30%,
      oklch(0.82 0.13 320),
      oklch(0.58 0.22 300) 55%,
      oklch(0.4 0.2 295)
    );
    box-shadow:
      0 0 60px oklch(0.6 0.22 305 / 0.7),
      inset 0 -14px 30px oklch(0.3 0.15 290 / 0.8);
  }

  .orb :global(.orb-mark) {
    position: absolute;
    top: 65px;
    left: 65px;
    color: oklch(0.98 0.02 90);
  }

  .moonlet {
    position: absolute;
    top: -4px;
    right: 12px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: oklch(0.92 0.09 85);
    box-shadow: 0 0 20px oklch(0.9 0.12 85);
  }

  h1 {
    font-size: clamp(46px, 7.5vw, 86px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0 0 22px;
  }

  .lede {
    font-size: 19px;
    line-height: 1.6;
    color: var(--text-2);
    max-width: 54ch;
    margin: 0 auto 36px;
  }

  .lede strong {
    color: #fff;
    font-weight: 600;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 999px;
  }

  .btn-primary {
    color: oklch(0.15 0.04 285);
    background: var(--amber);
    padding: 14px 26px;
    box-shadow: 0 8px 30px oklch(0.7 0.14 75 / 0.35);
  }

  .btn-primary:hover {
    background: var(--amber-hi);
    color: oklch(0.15 0.04 285);
  }

  .btn-ghost {
    color: var(--text);
    border: 1px solid oklch(1 0 0 / 0.2);
    padding: 14px 24px;
  }

  .btn-ghost:hover {
    border-color: oklch(0.84 0.12 80 / 0.6);
    color: var(--text);
  }

  .window-wrap {
    margin-top: 76px;
    position: relative;
  }

  .window-glow {
    position: absolute;
    inset: -2px;
    border-radius: 20px;
    background: radial-gradient(60% 80% at 50% 0%, oklch(0.6 0.22 305 / 0.55), transparent 70%);
    filter: blur(34px);
  }

  @media (max-width: 900px) {
    .window-wrap {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding: 32px 20px;
    }

    .lede {
      font-size: 17px;
    }

    .cta-row .btn {
      flex: 1 1 100%;
      justify-content: center;
    }
  }
</style>
