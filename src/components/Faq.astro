---
import { faq } from '../data/faq';
---

<section id="faq">
  <header class="head">
    <p class="eyebrow">questions fréquentes</p>
    <h2 class="serif">Tout ce qu'on nous demande <span class="accent">avant d'installer</span></h2>
  </header>

  <div class="grid">
    {
      faq.map((item) => (
        <article class="item">
          <h3>{item.q}</h3>
          <p>{item.a}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    position: relative;
    z-index: 1;
    max-width: var(--shell);
    margin: 0 auto;
    padding: 90px 32px 40px;
  }

  .head {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto 56px;
  }

  h2 {
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.06;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .item {
    border: 1px solid var(--hairline);
    border-radius: 18px;
    padding: 26px;
    background: var(--panel);
    backdrop-filter: blur(6px);
  }

  h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 10px;
    color: #fff;
    letter-spacing: -0.01em;
  }

  p {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-3);
    margin: 0;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    section {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
