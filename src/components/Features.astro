---
import Icon from './Icon.astro';
import { features } from '../data/site';
---

<section id="features">
  <header class="head">
    <p class="eyebrow">une constellation de détails</p>
    <h2 class="serif">
      Pensé pour la Merlin, <span class="accent">jusque dans le protocole</span>
    </h2>
  </header>

  <ul class="grid">
    {
      features.map((f) => (
        <li class="card" style={`--span:${f.span}`}>
          <span class="pin" aria-hidden="true" />
          <span class="icon">
            <Icon name={f.icon} size={22} />
          </span>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
          {f.chip && <code class="chip mono">{f.chip}</code>}
        </li>
      ))
    }
  </ul>
</section>

<style>
  section {
    position: relative;
    z-index: 1;
    max-width: var(--shell);
    margin: 0 auto;
    padding: 100px 32px 40px;
  }

  .head {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto 56px;
  }

  h2 {
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.06;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 18px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .card {
    grid-column: span var(--span);
    position: relative;
    border: 1px solid var(--hairline);
    border-radius: 18px;
    padding: 26px;
    background: var(--panel);
    backdrop-filter: blur(6px);
    overflow: hidden;
    transition:
      border-color 0.25s,
      transform 0.2s;
  }

  .card:hover {
    border-color: oklch(0.84 0.12 80 / 0.45);
    transform: translateY(-3px);
  }

  .pin {
    position: absolute;
    top: 20px;
    right: 22px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber-glow);
    box-shadow: 0 0 8px var(--amber-glow);
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    margin-bottom: 20px;
    border-radius: 13px;
    background: oklch(0.6 0.2 305 / 0.2);
    color: oklch(0.82 0.13 315);
  }

  h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
    color: #fff;
  }

  p {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--text-3);
    margin: 0;
  }

  .chip {
    display: inline-block;
    margin-top: 14px;
    padding: 4px 10px;
    font-size: 12px;
    color: oklch(0.82 0.1 315);
    background: oklch(0.6 0.2 305 / 0.16);
    border-radius: 7px;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }

    .card {
      grid-column: span 1;
    }

    .card:last-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 620px) {
    section {
      padding-left: 20px;
      padding-right: 20px;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .card,
    .card:last-child {
      grid-column: span 1;
    }
  }
</style>
